{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/artifact-report.schema.json",
  "title": "Artifact Report Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_id",
    "title",
    "template_version",
    "source_hashes",
    "sections",
    "components",
    "claims",
    "evidence",
    "verification",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "artifact-report.v1"
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "template_version": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "source_hashes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "summary"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "title": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "section_id", "purpose"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "type": {
            "type": "string",
            "enum": ["tldr", "summary", "diagram", "table", "folded_evidence", "command", "callout", "card"]
          },
          "section_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "purpose": { "type": "string", "minLength": 1 }
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "status", "evidence_ids"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "text": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["supported", "partial", "unsupported"] },
          "evidence_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "summary", "source"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "kind": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checks", "checked_at"],
      "properties": {
        "status": { "type": "string", "enum": ["passed", "failed", "partial"] },
        "checked_at": { "type": "string", "minLength": 1 },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "status"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "status": { "type": "string", "enum": ["passed", "failed", "partial"] },
              "detail": { "type": "string" }
            }
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
